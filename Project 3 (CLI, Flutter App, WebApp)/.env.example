# ═══════════════════════════════════════════════════════════════════════════════
# NSU Degree Audit Engine - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and configure your settings

# ─── Application Mode ─────────────────────────────────────────────────────────
# Options: development, production, testing
FLASK_ENV=production
DEBUG=false

# ─── Server Configuration ─────────────────────────────────────────────────────
# Host: 0.0.0.0 allows external connections, 127.0.0.1 is localhost only
HOST=0.0.0.0
PORT=5000

# Secret key for session security (generate a strong random key for production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ─── OCR Configuration ────────────────────────────────────────────────────────
# OCR.space API (free tier: 25,000 requests/month)
# Get your key at: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=K85858573688957

# Google Cloud Vision API (optional, higher accuracy)
# Leave empty to use OCR.space only
GOOGLE_CLOUD_VISION_KEY=

# OCR Engine preference: ocrspace, google, auto
# auto = tries Google first, falls back to OCR.space
OCR_ENGINE=auto

# ─── File Upload Limits ───────────────────────────────────────────────────────
MAX_CONTENT_LENGTH_MB=16
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ─── CORS (Cross-Origin Resource Sharing) ─────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Maximum requests per minute per IP
RATE_LIMIT=30

# ─── Database (if using persistence) ──────────────────────────────────────────
# DATABASE_URL=sqlite:///data/audit.db
