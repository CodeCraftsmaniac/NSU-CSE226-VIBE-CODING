# NSU Degree Audit - Environment Configuration
# ============================================
# Copy this file to .env and configure your settings
# IMPORTANT: Never commit .env with real API keys to version control!

# Server Configuration
PORT=5000
HOST=0.0.0.0
FLASK_ENV=production
DEBUG=false
SECRET_KEY=change-this-to-a-secure-random-string

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# File Upload
MAX_CONTENT_LENGTH_MB=16
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg

# ============================================
# OCR API Keys (Required - at least one)
# ============================================
# At least one OCR API key is required for scanned PDF processing.
# Digital PDFs can be processed without API keys (native text extraction).

# OCR.space API (Primary - easier to set up)
# Get your FREE key at: https://ocr.space/ocrapi/freekey
# Free tier: 500 requests/month
OCR_SPACE_API_KEY=your-ocr-space-api-key

# Google Cloud Vision API (Optional - more accurate)
# Setup steps:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or select existing)
# 3. Enable "Cloud Vision API" in APIs & Services
# 4. Create API key in Credentials section
# 5. (Recommended) Restrict key to Vision API only for security
# Free tier: 1000 requests/month
# GOOGLE_CLOUD_VISION_KEY=your-google-vision-api-key

# ============================================
# OCR Configuration (Advanced - Optional)
# ============================================
# Uncomment to customize OCR behavior

# Minimum confidence threshold for OCR text (0.0-1.0)
# Higher = fewer errors but may miss valid text
# Default: 0.7 (70% confidence)
# OCR_CONFIDENCE_THRESHOLD=0.7

# API request timeout in seconds
# Default: 30
# API_TIMEOUT=30
