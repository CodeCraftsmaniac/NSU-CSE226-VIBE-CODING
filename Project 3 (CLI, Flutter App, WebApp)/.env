# NSU Degree Audit - Production Configuration
# ============================================
# This file contains the production configuration settings.
# Keep API keys confidential and do not commit to public repositories.

# Server Configuration
PORT=5000
HOST=0.0.0.0
FLASK_ENV=production
DEBUG=false
SECRET_KEY=nsu-audit-prod-2024-secure-key-change-in-production

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# File Upload
MAX_CONTENT_LENGTH_MB=16
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg

# ============================================
# OCR API Keys Configuration
# ============================================
# At least one OCR API key is required for scanned PDF processing.
# Digital PDFs can be processed without API keys (native text extraction).

# OCR.space API (Primary)
# Get your FREE key at: https://ocr.space/ocrapi/freekey
# Free tier: 500 requests/month
OCR_SPACE_API_KEY=K86084037488957

# Google Cloud Vision API (More accurate, recommended)
# Setup: https://console.cloud.google.com/
# 1. Create project -> Enable Cloud Vision API
# 2. Create API key (restrict to Vision API for security)
# Free tier: 1000 requests/month
GOOGLE_CLOUD_VISION_KEY=AIzaSyA5YsERnW7V9UzpsqkgdFhldqY8LtpJPes

# ============================================
# OCR Configuration (Advanced)
# ============================================
# These settings affect OCR accuracy and performance.
# Defaults are optimized for most documents.

# Minimum confidence threshold for OCR text (0.0-1.0)
# Higher = fewer errors but may miss valid text
# Default: 0.7 (70% confidence)
# OCR_CONFIDENCE_THRESHOLD=0.7

# API request timeout in seconds
# Lower = faster failure detection, Higher = tolerates slow APIs
# Default: 30
# API_TIMEOUT=30
