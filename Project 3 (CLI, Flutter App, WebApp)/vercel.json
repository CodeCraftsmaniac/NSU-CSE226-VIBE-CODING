{
  "version": 2,
  "name": "nsu-degree-audit-engine",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": null,
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "web_app/app.py": {
      "runtime": "python3.11",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/web_app/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/web_app/app.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1",
    "VERCEL": "1"
  }
}
